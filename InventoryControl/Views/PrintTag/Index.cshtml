<body class="hold-transition sidebar-mini layout-fixed">

    <div class="wrapper">

        @Html.Partial("_Navbar")
        @Html.Partial("_Sidebar")

        <div class="content-wrapper">

            <div class="content-header">
                <div class="container-fluid">
                    <div class="row mb-2">

                        <div class="col-sm-6">
                            <h1>Print Tag</h1>
                        </div>

                        <div class="col-sm-6">
                            <ol class="breadcrumb float-sm-right">
                                <li class="breadcrumb-item"><a href="/home">Dashboard</a></li>
                                <li class="breadcrumb-item active">Print Tag</li>
                            </ol>
                        </div>

                    </div>
                </div>
            </div>

            <section class="content">
                <div class="container-fluid">

                    <div class="card card-primary">

                        <div class="card-header">
                            <h3 class="card-title">Print Tag</h3>
                        </div>

                        <div class="card-body">

                            <div class="row mb-3">
                                <div class="col-12 d-flex justify-content-end">
                                    <button class="btn btn-primary" data-toggle="modal" data-target="#createPrintTag">
                                        Create Print Tag
                                    </button>
                                </div>
                            </div>

                            <table id="datatablesIndex" class="table table-bordered table-hover">
                                <thead>
                                    <tr>
                                        <th>No</th>
                                        <th>DO Number</th>
                                        <th>Scanner</th>
                                        <th>Status</th>
                                        <th>Action</th>
                                    </tr>
                                </thead>
                            </table>

                        </div>

                    </div>

                </div>
            </section>

        </div>

        @Html.Partial("_Footer")

    </div>

    <!-- MODAL CREATE -->
    <div class="modal fade" id="createPickingList">
        <div class="modal-dialog">
            <div class="modal-content">

                <div class="modal-header">
                    <h5>Create PickingList</h5>
                    <button class="close" data-dismiss="modal">&times;</button>
                </div>

                <form id="createPickingListForm">
                    <div class="modal-body">

                        <div class="form-group">
                            <label>DO Number</label>
                            <input type="text" name="doNumber" class="form-control" required>
                        </div>

                        <div class="form-group">
                            <label>Scanner Type</label>
                            <select name="scannerType" class="form-control" required>
                                <option value="">-- Pilih Scanner --</option>
                                <option value="RFID">RFID</option>
                                <option value="QR">QR</option>
                            </select>
                        </div>

                        <div id="detailContainer"></div>

                        <button type="button" class="btn btn-sm btn-success" onclick="addDetail()">+ Item</button>

                    </div>

                    <div class="modal-footer">
                        <button type="submit" class="btn btn-primary">Create</button>
                    </div>
                </form>

            </div>
        </div>
    </div>

    @Html.Partial("_BaseScript")

    <script>

        async function loadItemDropdown() {

            const response = await fetch("/api/item", {
                method: "GET",
                credentials: "include"
            });

            const data = await response.json();

            console.log("ITEM DATA:", data); 

            let options = `<option value="">-- Select ITEM --</option>`;

            data.forEach(item => {
                options += `<option value="${item.id}">${item.itemName}</option>`;
            });

            $(".item-select").each(function () {
                if ($(this).children().length <= 1) {
                    $(this).html(options);
                }
            });
        }

        let table;

        $(document).ready(function () {
            loadDO();
        });

        async function loadDO() {

            const response = await fetch("/api/pickinglist", {
                method: "GET",
                credentials: "include"
            });

            const data = await response.json();

            if ($.fn.DataTable.isDataTable('#datatablesIndex')) {
                $('#datatablesIndex').DataTable().clear().destroy();
            }

            table = $("#datatablesIndex").DataTable({
                data: data,
                columns: [
                    { data: null, render: (d,t,r,m)=>m.row+1 },
                    { data: "doNumber" },
                    { data: "scannerType" },
                    { data: "status" },
                    {
                        data: null,
                        render: function (data) {
                            return `
                                <a href="/pickinglist/detail?id=${data.doId}" class="btn btn-info btn-sm">Detail</a>
                                <button class="btn btn-danger btn-sm"
                                    onclick="deletePickingList('${data.doId}')">
                                    Delete
                                </button>
                            `;
                        }
                    }
                ]
            });
        }
         $(document).on("click", ".remove-item", function () {

            let row = $(this).closest(".detail-item");

            Swal.fire({
                title: "Hapus item?",
                icon: "warning",
                showCancelButton: true,
                confirmButtonText: "Ya, hapus"
            }).then((result) => {
                if (result.isConfirmed) {
                    row.remove();

                    if ($("#detailContainer .detail-item").length === 0) {
                        $("#detailContainer").html("");
                    }
                }
            });
        });
        function addDetail() {

            if ($("#detailContainer .item-header").length === 0) {
                $("#detailContainer").append(`
                    <div class="row mb-2 item-header font-weight-bold">
                        <div class="col">Item</div>
                        <div class="col">Qty</div>
                        <div class="col-2 text-center">Action</div>
                    </div>
                `);
            }

            $("#detailContainer").append(`
                <div class="row mb-2 detail-item align-items-center">
                    <div class="col">
                        <select class="form-control item-select" required>
                            <option value="">-- Select Item --</option>
                        </select>
                    </div>
                    <div class="col">
                        <input class="form-control qty" placeholder="Qty" type="number">
                    </div>
                    <div class="col-2 text-center">
                        <button type="button" class="btn btn-danger btn-sm remove-item">
                            Hapus
                        </button>
                    </div>
                </div>
            `);

            loadItemDropdown();
        }

        $("#createPickingListForm").submit(async function (e) {
            e.preventDefault();

            const form = e.target;

            let details = [];

        $("#detailContainer .detail-item").each(function () {
            details.push({
                itemId: $(this).find(".item-select").val(),
                qtyRequired: parseInt($(this).find(".qty").val())
            });
        });

            const payload = {
                doNumber: form.doNumber.value,
                scannerType: form.scannerType.value,
                details
            };
        console.log("PAYLOAD:", payload);

            const response = await fetch("/api/pickinglist", {
                method: "POST",
                credentials: "include",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify(payload)
            });

            if (response.ok) {
                Swal.fire({
                    icon: "success",
                    title: "Picking List created",
                    timer: 1500,
                    showConfirmButton: false
                }).then(() => {
                    $("#createPickingList").modal("hide");
                    form.reset();
                    loadDO();
                });
            } else {
                Swal.fire({
                    icon: "error",
                    title: "Error",
                    text: "Failed to create Picking List"
                });
            }
        });

        async function deletePickingList(id) {

            if (!confirm("Delete Picking List ini?")) return;

            const response = await fetch(`/api/pickinglist/${id}`, {
                method: "DELETE",
                credentials: "include"
            });

            if (response.ok) {
                Swal.fire({
                    icon: "success",
                    title: "Deleted",
                    timer: 1500,
                    showConfirmButton: false
                }).then(() => {
                    loadDO();
                });
            } else {
                Swal.fire({
                    icon: "error",
                    title: "Error",
                    text: "Failed to delete"
                });
            }
        }

    </script>

</body>