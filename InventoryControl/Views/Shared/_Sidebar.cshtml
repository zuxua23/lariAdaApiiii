@using InventoryControl.Utility

<aside class="main-sidebar sidebar-light-primary elevation-2 sidebar-light-industrial">
    <a href="/home" class="brand-link">
        <img src="~/img/sato.svg" alt="Sato logo">
    </a>

    <div class="sidebar">

        <nav class="mt-2">

            <ul class="nav nav-pills nav-sidebar flex-column" data-widget="treeview">

                <!-- DASHBOARD -->
                <li class="nav-item">
                    <a asp-route="Home"
                       class="nav-link @(ViewData["pages"] == "home" ? "active" : "")">
                        <i class="nav-icon fas fa-home"></i>
                        <p>Dashboard</p>
                    </a>
                </li>


                <!-- MASTER -->
                @if (PermissionHelper.HasAnyPermission(Context,
                          "USER_GET", "ITEM_GET", "LOCATION_GET", "READER_GET"))
                {

                    <li class="nav-item @(ViewData["parent"]?.ToString() == "master" ? "menu-open" : "")">

                        <a href="#" class="nav-link @(ViewData["parent"]?.ToString() == "master" ? "active" : "")">
                            <i class="nav-icon fas fa-database"></i>
                            <p>
                                Master
                                <i class="fas fa-angle-left right"></i>
                            </p>
                        </a>

                        <ul class="nav nav-treeview">

                            @* USER *@
                            @if (PermissionHelper.HasPermission(Context, "USER_GET"))
                            {
                                <li class="nav-item">
                                    <a asp-controller="User"
                                    asp-action="Index"
                                    class="nav-link @(ViewData["pages"]?.ToString() == "user" ? "active" : "")">
                                        <i class="far fa-circle nav-icon"></i>
                                        <p>User</p>
                                    </a>
                                </li>
                            }

                            @* PRODUCT / ITEM *@
                            @if (PermissionHelper.HasPermission(Context, "ITEM_GET"))
                            {
                                <li class="nav-item">
                                    <a asp-controller="Item"
                                    asp-action="Index"
                                    class="nav-link @(ViewData["pages"]?.ToString() == "item" ? "active" : "")">
                                        <i class="far fa-circle nav-icon"></i>
                                        <p>Item</p>
                                    </a>
                                </li>
                            }

                            @* WAREHOUSE / LOCATION *@
                            @if (PermissionHelper.HasPermission(Context, "LOCATION_GET"))
                            {
                                <li class="nav-item">
                                    <a asp-controller="Location"
                                    asp-action="Index"
                                    class="nav-link @(ViewData["pages"]?.ToString() == "location" ? "active" : "")">
                                        <i class="far fa-circle nav-icon"></i>
                                        <p>Location</p>
                                    </a>
                                </li>
                            }

                            @* READER *@
                            @if (PermissionHelper.HasPermission(Context, "READER_GET"))
                            {
                                <li class="nav-item">
                                    <a asp-controller="Reader"
                                    asp-action="Index"
                                    class="nav-link @(ViewData["pages"]?.ToString() == "reader" ? "active" : "")">
                                        <i class="far fa-circle nav-icon"></i>
                                        <p>Reader</p>
                                    </a>
                                </li>
                            }

                        </ul>

                    </li>
                }


                <!-- PRINTING -->
                @if (PermissionHelper.HasAnyPermission(Context, "TAG_PRINT", "TAG_REGISTER"))
                {
                    <li class="nav-item">
                        <a asp-route="tag"
                           class="nav-link">
                            <i class="nav-icon fas fa-print"></i>
                            <p>Printing</p>
                        </a>
                    </li>
                }


                <!-- PICKING -->
                @if (PermissionHelper.HasPermission(Context, "PICKINGLIST_GET"))
                {
                    <li class="nav-item">
                        <a asp-controller="PickingList"
                           class="nav-link @(ViewData["pages"] == "pickinglist" ? "active" : "")">
                            <i class="nav-icon fas fa-edit"></i>
                            <p>Picking</p>
                        </a>
                    </li>
                }


                <!-- LOADING -->
                @if (PermissionHelper.HasPermission(Context, "STOCK_OUT"))
                {
                    <li class="nav-item">
                        <a asp-route="loading"
                           class="nav-link">
                            <i class="nav-icon fas fa-tasks"></i>
                            <p>Loading Verification</p>
                        </a>
                    </li>
                }


                <!-- REPORT -->
                @if (PermissionHelper.HasPermission(Context, "DO_GET"))
                {
                    <li class="nav-item">
                        <a asp-route="report"
                           class="nav-link">
                            <i class="nav-icon fas fa-file-alt"></i>
                            <p>Report</p>
                        </a>
                    </li>
                }


                <!-- LOGOUT -->
                <li class="nav-item logout-item">
                    <a href="#" onclick="logoutConfirm()" class="nav-link">
                        <i class="nav-icon fas fa-sign-out-alt"></i>
                        <p>Logout</p>
                    </a>
                </li>

            </ul>

        </nav>

    </div>
    <script>
        function logoutConfirm() {
            Swal.fire({
                title: "Logout?",
                text: "Keluar dari sistem?",
                icon: "question",
                showCancelButton: true,
                confirmButtonColor: "#dc3545",
                cancelButtonColor: "#6c757d",
                confirmButtonText: "Logout",
                cancelButtonText: "Batal"
            }).then((result) => {
                if (result.isConfirmed) {
                    window.location.href = "/logout";
                }
            });
        }
    </script>
</aside>