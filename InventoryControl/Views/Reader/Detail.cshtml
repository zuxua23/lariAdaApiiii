<body class="hold-transition sidebar-mini layout-fixed">

<div class="wrapper">

    @Html.Partial("_Navbar")
    @Html.Partial("_Sidebar")

    <div class="content-wrapper">

        <div class="content-header">
            <div class="container-fluid">

                <div class="row mb-2">

                    <div class="col-sm-6">
                        <h1>Detail Reader</h1>
                    </div>

                    <div class="col-sm-6">
                        <ol class="breadcrumb float-sm-right">
                            <li class="breadcrumb-item"><a href="/home">Dashboard</a></li>
                            <li class="breadcrumb-item"><a href="/reader">Reader</a></li>
                            <li class="breadcrumb-item active">Detail</li>
                        </ol>
                    </div>

                </div>
            </div>
        </div>

        <section class="content">
            <div class="container-fluid">

                <div class="card card-primary">

                    <div class="card-header">
                        <h3 class="card-title">Reader Detail</h3>
                    </div>

                    <div class="card-body">

                        <div class="form-group">
                            <label>Reader ID</label>
                            <input id="rdrId" class="form-control" readonly>
                        </div>

                        <div class="form-group">
                            <label>Name</label>
                            <input id="rdrName" class="form-control">
                        </div>

                            <div class="form-group">
                                <label>Location</label>

                                <input type="hidden" id="locId">

                                <input id="locationName" class="form-control" readonly>
                            </div>

                        <div class="form-group">
                            <label>IP Address</label>
                            <input id="ipAddress" class="form-control">
                        </div>

                        <div class="d-flex justify-content-end">
                            <button class="btn btn-primary" onclick="updateReader()">
                                Update
                            </button>
                        </div>

                    </div>

                </div>

            </div>
        </section>

    </div>

    @Html.Partial("_Footer")

</div>

@Html.Partial("_BaseScript")

<script>

let id = "@ViewData["id"]";

$(document).ready(function () {
    loadReader();
});

async function loadReader() {

    const response = await fetch(`/api/reader/${id}`, {
        method: "GET",
        credentials:"include",
    });

    const data = await response.json();

    $("#rdrId").val(data.rdrId);
    $("#rdrName").val(data.rdrName);
    $("#locId").val(data.locId);
    $("#locationName").val(data.locationName);
    $("#ipAddress").val(data.ipAddress);
}

async function updateReader() {

    const payload = {
            rdrId: $("#rdrId").val(),
            rdrName: $("#rdrName").val(),
            locId: $("#locId").val(),
            ipAddress: $("#ipAddress").val()
        
    };

    const response = await fetch(`/api/reader/${id}`, {
        method: "PUT",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(payload)
    });

    if (response.ok) {
        alert("Reader updated");
    } else {
        alert("Update gagal");
    }
}

</script>

</body>