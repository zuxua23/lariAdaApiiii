@using InventoryControl.Utility

@{
    var canCreate = PermissionHelper.HasPermission(Context, "READER_CREATE");
    var canUpdate = PermissionHelper.HasPermission(Context, "READER_UPDATE");
    var canDelete = PermissionHelper.HasPermission(Context, "READER_DELETE");
}

<body class="hold-transition sidebar-mini layout-fixed">

    <div class="wrapper">

        @Html.Partial("_Navbar")
        @Html.Partial("_Sidebar")
        @Html.Partial("_Views")

        <div class="content-wrapper">

            <section class="content-header">
                <div class="container-fluid">
                    <div class="d-flex align-items-center justify-content-between flex-wrap mb-4">

                        <div class="d-flex align-items-center">
                            <div class="header-icon mr-3">
                                <i class="fas fa-broadcast-tower nav-icon text-primary"
                                   style="font-size: 2.25rem; opacity: 0.8;"></i>
                            </div>
                            <div>
                                <h1 class="h3 mb-1 text-dark font-weight-bold">Reader Management</h1>
                                <p class="mb-0 text-muted small">Manage reader devices</p>
                            </div>
                        </div>

                        <nav class="modern-breadcrumb">
                            <ol class="breadcrumb bg-transparent p-0 mb-0">
                                <li class="breadcrumb-item">
                                    <a href="/dashboard" class="text-muted">
                                        <i class="fas fa-home mr-1"></i>Dashboard
                                    </a>
                                </li>
                                <li class="breadcrumb-item active">
                                    <i class="fas fa-broadcast-tower mr-1"></i>Reader
                                </li>
                            </ol>
                        </nav>

                    </div>
                </div>
            </section>

            <section class="content">
                <div class="container-fluid">

                    <div class="card card-primary card-outline shadow-lg">

                        <div class="card-header bg-white border-0 pb-0">
                            <div class="d-flex justify-content-between align-items-center">
                                <h3 class="card-title font-weight-bold mb-0">
                                    <i class="fas fa-list mr-2 text-primary"></i>
                                    Reader List
                                </h3>
                                @if (canCreate)
                                {
                                    <button class="btn btn-primary btn-icon-split"
                                    data-toggle="modal"
                                    data-target="#createReader">
                                        <span class="icon text-white-50">
                                            <i class="fas fa-plus"></i>
                                        </span>
                                        <span class="text">Create</span>
                                    </button>
                                }
                            </div>
                        </div>

                        <div class="card-body pt-3">

                            <div class="table-responsive">
                                <table id="datatablesIndex" class="table table-hover">
                                    <thead class="thead-light">
                                        <tr>
                                            <th class="text-center" width="60"></th>
                                            <th class="text-nowrap">Reader ID</th>
                                            <th>Name</th>
                                            <th>Location</th>
                                            <th>IP Address</th>
                                            @if (canUpdate || canDelete)
                                            {
                                             <th class="text-center" width="160">Actions</th>
                                            }
                                        </tr>
                                    </thead>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            </section>
        </div>
        @Html.Partial("_Footer")
    </div>

    <div class="modal fade" id="createReader">
        <div class="modal-dialog">
            <div class="modal-content">

                <div class="modal-header">
                    <h5>Create Reader</h5>
                    <button class="close" data-dismiss="modal">&times;</button>
                </div>

                <form id="createReaderForm">
                    <div class="modal-body">

                        <div class="form-group">
                            <label><i class="fas fa-hashtag mr-2"></i>Reader ID <span class="text-danger">*</span></label>
                            <input type="text" name="rdrId" class="form-control" required>
                        </div>

                        <div class="form-group">
                            <label><i class="fas fa-tag mr-2"></i>Name <span class="text-danger">*</span></label>
                            <input type="text" name="rdrName" class="form-control" required>
                        </div>

                        <div class="form-group">
                            <label><i class="fas fa-map-marker-alt mr-2"></i>Location <span class="text-danger">*</span></label>
                            <select name="locId" id="locIdSelect" class="form-control" required></select> 
                        </div>

                        <div class="form-group">
                            <label><i class="fas fa-network-wired mr-2"></i>IP Address <span class="text-danger">*</span></label>
                            <input type="text" name="ipAddress" pattern="^(\d{1,3}\.){3}\d{1,3}$" class="form-control" required>
                        </div>

                    </div>

                    <div class="modal-footer">
                        <button type="submit" class="btn btn-primary btn-modern">
                            <i class="fas fa-save mr-1"></i>Create
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    @Html.Partial("_BaseScript")

    <script src="~/helper/api.js"></script>
    <script src="~/helper/alert.js"></script>
    <script src="~/helper/table.js"></script>

    <script>
        const canUpdate = @canUpdate.ToString().ToLower();
        const canDelete = @canDelete.ToString().ToLower();

        let table;

        $(document).ready(function () {
            loadReaders();
        });

        async function loadLocationDropdown() {

            const data = await Api.get("/api/location");

            if (!data) {
                Alert.error("Failed to load locations");
                return;
            }

            let options = `<option></option>`;

            data.forEach(loc => {
                options += `<option value="${loc.id}">${loc.name}</option>`;
            });

            $("#locIdSelect").html(options);
            initSelect2();
        }

        function initSelect2() {
            $('#locIdSelect').select2({
                theme: 'bootstrap4',
                placeholder: "Search location...",
                allowClear: true,
                width: '100%',
                dropdownParent: $('#createReader')
            });
        }

        $(document).on('select2:open', () => {
            document.querySelector('.select2-container--open .select2-search__field').focus();
        });


        async function loadReaders() {

            const data = await Api.get("/api/reader");
            if (!data) return;

            table = Table.init("#datatablesIndex", {
                data: data,
                columns: [
                    Table.rowNumber(),
                    { data: "rdrId" },
                    { data: "rdrName" },
                    { data: "locationName", defaultContent: "-" },
                    { data: "ipAddress" },
                    Table.action(renderAction, canUpdate || canDelete)
                ]
            });
        }

        function renderAction(data) {

            let buttons = `<div class="btn-group btn-group-sm">`;

            if (canUpdate) {
                buttons += `
                    <a href="/reader/detail?id=${data.id}" class="btn btn-info">
                        <i class="fas fa-eye"></i>
                    </a>
                `;
            }

            if (canDelete) {
                buttons += `
                    <button class="btn btn-danger"
                            onclick="deleteReader('${data.id}')">
                        <i class="fas fa-trash"></i>
                    </button>
                `;
            }

            buttons += `</div>`;
            return buttons;
        }

        $("#createReaderForm").submit(async function (e) {
            e.preventDefault();

            const form = e.target;

            if (!form.locId.value) {
                Alert.error("Location is required");
                return;
            }

            const payload = {
                rdrId: form.rdrId.value,
                rdrName: form.rdrName.value,
                locId: form.locId.value,
                ipAddress: form.ipAddress.value
            };

            const res = await Api.post("/api/reader", payload);

            if (res && res.ok) {

                await Alert.success("Reader created successfully");

                $("#createReader").modal("hide");
                form.reset();
                $("#locIdSelect").val(null).trigger("change");
                loadReaders();


            } else if (res && !res.ok) {
                  if (res.errorData?.type === "warning")
                  return;

                Alert.error("Failed to create reader");
            }
        });

        async function deleteReader(id) {

            const confirm = await Alert.deleteConfirm("Reader", "This Reader will be permanently deleted!");
            if (!confirm.isConfirmed) return;

            const res = await Api.delete(`/api/reader/${id}`);

            if (res && res.ok) {

                await Alert.success("Reader deleted successfully");
                loadReaders();
            } else if (res && !res.ok) {
                    if (res.errorData?.type === "warning")
                    return;
    
                    Alert.error("Failed to delete reader");
                }
        }

        $('#createReader').on('shown.bs.modal', function () {
            loadLocationDropdown();
        });

    </script>

</body>