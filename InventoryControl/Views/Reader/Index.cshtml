<body class="hold-transition sidebar-mini layout-fixed">

<div class="wrapper">

    @Html.Partial("_Navbar")
    @Html.Partial("_Sidebar")

    <div class="content-wrapper">

        <div class="content-header">
            <div class="container-fluid">
                <div class="row mb-2">

                    <div class="col-sm-6">
                        <h1>Reader</h1>
                    </div>

                    <div class="col-sm-6">
                        <ol class="breadcrumb float-sm-right">
                            <li class="breadcrumb-item"><a href="/dashboard">Dashboard</a></li>
                            <li class="breadcrumb-item active">Reader</li>
                        </ol>
                    </div>

                </div>
            </div>
        </div>

        <section class="content">
            <div class="container-fluid">

                <div class="card card-primary">

                    <div class="card-header">
                        <h3 class="card-title">Reader List</h3>
                    </div>

                    <div class="card-body">

                        <div class="row mb-3">
                            <div class="col-12 d-flex justify-content-end">
                                <button class="btn btn-primary" data-toggle="modal" data-target="#createReader">
                                    Create Reader
                                </button>
                            </div>
                        </div>

                        <table id="datatablesIndex" class="table table-bordered table-hover">
                            <thead>
                                <tr>
                                    <th>No</th>
                                    <th>Reader ID</th>
                                    <th>Name</th>
                                    <th>Location</th>
                                    <th>IP Address</th>
                                    <th>Action</th>
                                </tr>
                            </thead>
                        </table>

                    </div>

                </div>

            </div>
        </section>

    </div>

    @Html.Partial("_Footer")

</div>

<!-- MODAL -->
<div class="modal fade" id="createReader">
    <div class="modal-dialog">
        <div class="modal-content">

            <div class="modal-header">
                <h5>Create Reader</h5>
                <button class="close" data-dismiss="modal">&times;</button>
            </div>

            <form id="createReaderForm">
                <div class="modal-body">

                    <div class="form-group">
                        <label>Reader ID</label>
                        <input type="text" name="rdrId" class="form-control" required>
                    </div>

                    <div class="form-group">
                        <label>Name</label>
                        <input type="text" name="rdrName" class="form-control" required>
                    </div>

                        <div class="form-group">
                            <label>Location</label>
                            <select name="locId" id="locIdSelect" class="form-control" required>
                                <option value="">-- Select Location --</option>
                            </select>
                        </div>

                    <div class="form-group">
                        <label>IP Address</label>
                        <input type="text" name="ipAddress" class="form-control" required>
                    </div>

                </div>

                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">Close</button>
                    <button type="submit" class="btn btn-primary">Create</button>
                </div>
            </form>

        </div>
    </div>
</div>

@Html.Partial("_BaseScript")

<script>


        async function loadLocationDropdown() {

            const response = await fetch("/api/location", {
                method: "GET",
                        credentials: "include"
            });

            const data = await response.json();

            let options = `<option value="">-- Select Location --</option>`;

            data.forEach(loc => {
                options += `<option value="${loc.id}">${loc.name}</option>`;
            });

            $("#locIdSelect").html(options);
        }

let table;

$(document).ready(function () {
    loadReaders();
});

async function loadReaders() {

    const response = await fetch("/api/reader", {
        method: "GET",
                credentials: "include"
    });

    const data = await response.json();

    if ($.fn.DataTable.isDataTable('#datatablesIndex')) {
        $('#datatablesIndex').DataTable().clear().destroy();
    }

    table = $("#datatablesIndex").DataTable({
        data: data,
        columns: [
            {
                data: null,
                render: (data, type, row, meta) => meta.row + 1
            },
            { data: "rdrId" },
            { data: "rdrName" },
            {data: "locationName",defaultContent : "-"},
            { data: "ipAddress" },
            {
                data: null,
                render: function (data) {
                    return `
                        <a href="/reader/detail?id=${data.id}" class="btn btn-info btn-sm">Detail</a>
                        <button class="btn btn-danger btn-sm"
                            onclick="deleteReader('${data.id}')">
                            Delete
                        </button>
                    `;
                }
            }
        ]
    });
}

$("#createReaderForm").submit(async function (e) {
    e.preventDefault();

    const form = e.target;

    const payload = {
            rdrId: form.rdrId.value,
            rdrName: form.rdrName.value,
            locId: form.locId.value,
            ipAddress: form.ipAddress.value
    };
            console.log("Payload:", payload);
            if (!form.locId.value) {
            Swal.fire({
                icon: "warning",
                title: "Location wajib dipilih"
            });
            return;
        }
    const response = await fetch("/api/reader", {
        method: "POST",
        credentials: "include",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(payload)
    });

    if (response.ok) {
        Swal.fire({
            icon: "success",
            title: "Reader created",
            timer: 1500,
            showConfirmButton: false
         }).then(() => {
        $("#createReader").modal("hide");
        form.reset();
        loadReaders();
        });
    } else {
        Swal.fire({
            icon: "error",
            title: "Error",
            text: "Failed to create reader"
                });
    }
});

        async function deleteReader(id) {

            if (!confirm("Delete reader ini?")) return;

            const response = await fetch(`/api/reader/${id}`, {
                method: "DELETE",
                credentials: "include"
            });

            if (response.ok) {
                Swal.fire({
                    icon: "success",
                    title: "Reader deleted",
                    timer: 1500,
                    showConfirmButton: false
                }).then(() => {
                    loadReaders();
                });
            } else {
                Swal.fire({
                    icon: "error",
                    title: "Error",
                    text: "Failed to delete reader"
                });
            }
        }

        $('#createReader').on('shown.bs.modal', function () {
            loadLocationDropdown();
        });

</script>

</body>