<body class="hold-transition sidebar-mini layout-fixed">

    <div class="wrapper">

        @Html.Partial("_Navbar")
        @Html.Partial("_Sidebar")
        @Html.Partial("_Views")

        <div class="content-wrapper">

            <section class="content-header">
                <div class="container-fluid">
                    <div class="d-flex align-items-center justify-content-between flex-wrap mb-4">

                        <div class="d-flex align-items-center">
                            <div class="header-icon mr-3">
                                <i class="fas fa-print nav-icon text-primary"
                                   style="font-size: 2.25rem; opacity: 0.8;"></i>
                            </div>
                            <div>
                                <h1 class="h3 mb-1 text-dark font-weight-bold">Print Tag</h1>
                                <p class="mb-0 text-muted small">Manage tag printing process</p>
                            </div>
                        </div>

                        <nav aria-label="breadcrumb" class="modern-breadcrumb">
                            <ol class="breadcrumb bg-transparent p-0 mb-0">
                                <li class="breadcrumb-item">
                                    <a href="/dashboard" class="text-muted">
                                        <i class="fas fa-home mr-1"></i>Dashboard
                                    </a>
                                </li>
                                <li class="breadcrumb-item active">
                                    <i class="fas fa-clipboard-list mr-1"></i>Print Tag
                                </li>
                            </ol>
                        </nav>

                    </div>
                </div>
            </section>

            <section class="content">
                <div class="container-fluid">
                    <div class="row mb-4">
                        <div class="col-md-8">
                            <div class="card card-primary card-outline shadow-lg h-100">
            
                                <div class="card-header bg-white border-0 pb-0">
                                    <div class="d-flex justify-content-between align-items-center">
                                        <h3 class="card-title font-weight-bold mb-0">
                                            <i class="fas fa-list mr-2 text-primary"></i>
                                            Item List
                                        </h3>
                                    </div>
                                </div>

                                <div class="card-body pt-3">
                                    <table class="table table-bordered table-hover" id="tagTable">
                                        <thead class="thead-light">
                                            <tr>
                                                <th width="60"></th>
                                                <th>Item</th>
                                                <th width="120">Qty</th>
                                                <th width="100">Action</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <tr>
                                                <td>1</td>
                                                <td>
                                                    <select class="form-control select2 item-select" data-row="1" id="firstItemSelect"></select>
                                                </td>
                                                <td>
                                                    <input type="number" class="form-control qty-input" min="1" max="100" value="1">
                                                </td>
                                                <td>
                                                    <button class="btn btn-sm btn-danger" onclick="removeRow(this)">
                                                        <i class="fas fa-trash"></i>
                                                    </button>
                                                </td>
                                            </tr>
                                        </tbody>
                                    </table>

                                    <button class="btn btn-primary mt-3" onclick="addRow()">
                                        <i class="fas fa-plus"></i> Add Row
                                    </button>
                                </div>
            
                            </div>
                        </div>

                        <div class="col-md-4">
                            <div class="card shadow-lg">
                                <div class="card-header bg-success text-white">
                                    <h6 class="mb-0">
                                        <i class="fas fa-print mr-2"></i>Print
                                    </h6>
                                </div>
                                <div class="card-body d-flex flex-column">

                                    <div class="form-group text-center">
                                        <label class="font-weight-bold text-muted">Total Tag</label>
                                        <div id="totalTags"
                                             class="badge badge-primary badge-lg d-block p-3 text-center"
                                             style="font-size: 1.5rem;">
                                            0
                                        </div>
                                    </div>

                                    <button class="btn btn-primary btn-block mt-auto" style="font-size: 1.5rem;" onclick="printTags()">
                                        <i class="fas fa-print mr-2"></i>Print Tags
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>

                            <div class="row">
                                <div class="col-12">

                                    <div class="card card-primary card-outline shadow-lg">

                                        <div class="card-header bg-white border-0 pb-0">
                                            <div class="d-flex justify-content-between align-items-center">
                                                <h3 class="card-title font-weight-bold mb-0">
                                                    <i class="fas fa-list mr-2 text-primary"></i>
                                                    Tag Data List
                                                </h3>
                                            </div>
                                        </div>

                                        <div class="card-body pt-3">

                                            <div class="table-responsive">
                                                <table id="datatablesIndex" class="table table-hover">
                                                    <thead class="thead-light">
                                                        <tr>
                                                            <th class="text-center" width="60"></th>
                                                            <th>Tag ID</th>
                                                            <th>Item Name</th>
                                                            <th>Epc</th>
                                                            <th>Location</th>
                                                            <th>Status</th>
                                                        </tr>
                                                    </thead>
                                                </table>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
            </section>                
        </div>
        @Html.Partial("_Footer")

    </div>

  
    @Html.Partial("_BaseScript")
    
    <script src="~/helper/api.js"></script>
    <script src="~/helper/alert.js"></script>
    <script src="~/helper/table.js"></script>
    <script>

        let table;
        let rowCounter = 1;

        $(document).ready(function () {
            loadItemsDropdown(document.getElementById("firstItemSelect"));
            loadTagTable();
            updateTotalTags();
        });

        async function loadTagTable() {

            const data = await Api.get("/api/tag");
            if (!data) return;

            table = Table.init("#datatablesIndex", {
                data: data,
                columns: [
                    Table.rowNumber(),
                    {
                        data: "tagId",
                        render: d => `<code>${d}</code>`
                    },
                    { data: "itemName" },
                    { data: "epc" },
                    { data: "location" },
                    {
                        data: "status",
                        render: function (data) {
                            if (data === "IN") return `<span class="badge badge-success">IN</span>`;
                            if (data === "OUT") return `<span class="badge badge-danger">OUT</span>`;
                            return `<span class="badge badge-secondary">${data || "-"}</span>`;
                        }
                    }
                ]
            });
        }

        async function loadItemsDropdown(selectElement) {

            const data = await Api.get("/api/item");
            if (!data) return Alert.error("Failed to load items");

            let options = `<option value="">-- Select Item --</option>`;

            data.forEach(item => {
                options += `<option value="${item.id}">${item.itemName}</option>`;
            });

            selectElement.innerHTML = options;
            initSelect2(selectElement.parentElement);
        }

        function initSelect2(parent = document) {
            $(parent).find('.select2').select2({
                theme: 'bootstrap4',
                placeholder: "Search...",
                width: '100%',
                dropdownParent: $('body')
            });
        }

        $(document).on('select2:open', () => {
            document.querySelector('.select2-container--open .select2-search__field').focus();
        });

        function addRow() {

            rowCounter++;

            const tbody = document.querySelector('#tagTable tbody');

            const newRow = document.createElement('tr');
            newRow.innerHTML = `
                <td>${rowCounter}</td>
                <td>
                    <select class="form-control select2 item-select"></select>
                </td>
                <td>
                    <input type="number" class="form-control qty-input" min="1" max="1000" value="1">
                </td>
                <td>
                    <button class="btn btn-sm btn-danger" onclick="removeRow(this)">
                        <i class="fas fa-trash"></i>
                    </button>
                </td>
            `;

            tbody.appendChild(newRow);

            const select = newRow.querySelector('.item-select');
            loadItemsDropdown(select);

            updateTotalTags();
        }

        async function removeRow(button) {

            const confirm = await Alert.confirm({
                text: "Delete row?"
            });

            if (!confirm.isConfirmed) return;

            button.closest('tr').remove();

            updateRowNumbers();
            updateTotalTags();
        }

        function updateRowNumbers() {
            const rows = document.querySelectorAll('#tagTable tbody tr');

            rows.forEach((row, index) => {
                row.cells[0].textContent = index + 1;
            });

            rowCounter = rows.length;
        }

        function updateTotalTags() {

            let total = 0;

            document.querySelectorAll('.qty-input').forEach(input => {
                total += parseInt(input.value) || 0;
            });

            document.getElementById('totalTags').textContent = total.toLocaleString();
        }

        document.addEventListener('input', function (e) {
            if (e.target.classList.contains('qty-input')) {
                updateTotalTags();
            }
        });

        async function printTags() {

            const btn = document.querySelector("button[onclick='printTags()']");
            btn.disabled = true;

            const rows = document.querySelectorAll('#tagTable tbody tr');

            let payload = [];
            let isValid = true;

            rows.forEach(row => {

                const itemId = row.querySelector('.item-select').value;
                const qty = row.querySelector('.qty-input').value;

                if (!itemId) isValid = false;

                if (itemId && qty > 0) {
                    payload.push({
                        itemId,
                        qty: parseInt(qty)
                    });
                }
            });

            if (!isValid) {
                Alert.error("Please select item in all rows");
                btn.disabled = false;
                return;
            }

            if (payload.length === 0) {
                Alert.error("Please add at least one item");
                btn.disabled = false;
                return;
            }

            Swal.fire({
                title: "Printing...",
                allowOutsideClick: false,
                didOpen: () => Swal.showLoading()
            });

            try {

                const res = await Api.post("/api/tag/print", payload);

                if (res && res.ok) {

                    await Alert.success("Tags printed successfully");

                    resetForm();
                    loadTagTable();


                } else if (res && !res.ok) {
                      if (res.errorData?.type === "warning")
                      return;

                    Alert.error("Failed to print tags");
                }
            } catch (err) {

                Alert.error(err.message);

            } finally {

                btn.disabled = false;

            }
        }

        function resetForm() {

            const tbody = document.querySelector('#tagTable tbody');

            tbody.innerHTML = `
                <tr>
                    <td>1</td>
                    <td>
                        <select class="form-control select2 item-select" id="firstItemSelect"></select>
                    </td>
                    <td>
                        <input type="number" class="form-control qty-input" value="1">
                    </td>
                    <td></td>
                </tr>
            `;

            rowCounter = 1;

            loadItemsDropdown(document.getElementById("firstItemSelect"));
            updateTotalTags();
        }

    </script>

</body>