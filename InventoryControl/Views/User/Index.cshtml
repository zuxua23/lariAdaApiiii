@using InventoryControl.Utility
@{
    var canCreate = PermissionHelper.HasPermission(Context, "USER_CREATE");
    var canUpdate = PermissionHelper.HasPermission(Context, "USER_UPDATE");
    var canDelete = PermissionHelper.HasPermission(Context, "USER_DELETE");
}
<body class="hold-transition sidebar-mini layout-fixed">

    <div class="wrapper">

        @Html.Partial("_Navbar")
        @Html.Partial("_Sidebar")
        @Html.Partial("_Views")

        <div class="content-wrapper">

            <section class="content-header">
                <div class="container-fluid">
                    <div class="d-flex align-items-center justify-content-between flex-wrap mb-4">

                        <div class="d-flex align-items-center">
                            <div class="header-icon mr-3">
                                <i class="fas fa-users nav-icon text-primary"
                                   style="font-size: 2.25rem; opacity: 0.8;"></i>
                            </div>
                            <div>
                                <h1 class="h3 mb-1 text-dark font-weight-bold">User Management</h1>
                                <p class="mb-0 text-muted small">Manage system users</p>
                            </div>
                        </div>

                        <nav class="modern-breadcrumb">
                            <ol class="breadcrumb bg-transparent p-0 mb-0">
                                <li class="breadcrumb-item">
                                    <a href="/dashboard" class="text-muted">
                                        <i class="fas fa-home mr-1"></i>Dashboard
                                    </a>
                                </li>
                                <li class="breadcrumb-item active">
                                    <i class="fas fa-users mr-1"></i>User
                                </li>
                            </ol>
                        </nav>

                    </div>
                </div>
            </section>

            <section class="content">
                <div class="container-fluid">

                    <div class="card card-primary card-outline shadow-lg">

                        <div class="card-header bg-white border-0 pb-0">
                            <div class="d-flex justify-content-between align-items-center">
                                <h3 class="card-title font-weight-bold mb-0">
                                    <i class="fas fa-list mr-2 text-primary"></i>
                                    User List
                                </h3>
                                @if (canCreate)
                                {
                                    <button class="btn btn-primary btn-icon-split"
                                    data-toggle="modal"
                                    data-target="#createUser">
                                        <span class="icon text-white-50">
                                            <i class="fas fa-plus"></i>
                                        </span>
                                        <span class="text">Create</span>
                                    </button>
                                }
                            </div>
                        </div>

                      
                        <div class="card-body pt-3">
                            <div class="table-responsive">
                                <table id="datatablesIndex" class="table table-hover ">
                                    <thead class="thead-light">
                                        <tr>
                                            <th class="text-center" width="60"></th>
                                            <th class="text-nowrap">User ID</th>
                                            <th>Full Name</th>
                                            <th>Username</th>
                                            <th>Role</th>
                                            @if (canUpdate || canDelete)
                                            {
                                            <th class="text-center" width="160">Actions</th>
                                            }
                                        </tr>
                                    </thead>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            </section>

        </div>

        @Html.Partial("_Footer")

    </div>

    <div class="modal fade" id="createUser">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">

                <div class="modal-header">
                    <h5>Create User</h5>
                    <button class="close" data-dismiss="modal">&times;</button>
                </div>

                <form id="createUserForm">
                    <div class="modal-body">

                        <div class="row">

                            <div class="col-6">
                                <div class="form-group">
                                    <label><i class="fas fa-hashtag mr-2"></i>User ID</label>
                                    <input type="text" id="userId" name="userId" class="form-control" readonly>
                                </div>
                            </div>

                            <div class="col-6">
                                <div class="form-group">
                                    <label><i class="fas fa-id-card mr-2"></i>Full Name <span class="text-danger">*</span></label>
                                    <input type="text" name="fullname" class="form-control" required>
                                </div>
                            </div>

                        </div>

                        <div class="row">

                            <div class="col-6">
                                <div class="form-group">
                                    <label><i class="fas fa-user mr-2"></i>Username <span class="text-danger">*</span></label>
                                    <input type="text" name="username" class="form-control" required>
                                </div>
                            </div>

                            <div class="col-6">
                                <div class="form-group">
                                    <label><i class="fas fa-lock mr-2"></i>Password <span class="text-danger">*</span></label>
                                    <input type="password" name="password" class="form-control" required>
                                </div>
                            </div>
                                <div class="col-12">
                                    <div class="form-group">
                                    <label><i class="fas fa-user-shield mr-2"></i>Role <span class="text-danger">*</span></label>
                                    <select id="roleSelect" name="roleIds" class="form-control select2" multiple style="width:100%"><option></option></select>
                                    </div>
                                </div>

                        </div>


                            <div class="modal-footer">
                                <button class="btn btn-primary btn-modern">
                                    <i class="fas fa-save mr-1"></i>Create
                                </button>
                            </div>

                    </div>
                </form>
                    </div>

            </div>
        </div>
    </div>

    @Html.Partial("_BaseScript")
    <script src="~/helper/api.js"></script>
    <script src="~/helper/alert.js"></script>
    <script src="~/helper/table.js"></script>

    <script>

        const canUpdate = @canUpdate.ToString().ToLower();
        const canDelete = @canDelete.ToString().ToLower();

        let table;

        $(document).ready(function () {
            loadUsers();
            $(window).trigger('resize');
        });

        async function loadRolesDropdown() {

            const roles = await Api.get("/api/permission");
            if (!roles) {
                Alert.error("Failed to load roles");
                return;
            }

            let options = roles.map(r =>
                `<option value="${r.id}">${r.name}</option>`
            ).join("");

            $("#roleSelect").html(options);
            initSelect2();
        }

        function initSelect2(parent = document) {
            $(parent).find('.select2').select2({
                theme: 'bootstrap4',
                placeholder: "Select roles...",
                allowClear: true,
                width: '100%',
                dropdownParent: $('body'),
                closeOnSelect: false
            });
        }

        $(document).on('select2:open', () => {
            document.querySelector('.select2-container--open .select2-search__field').focus();
        });

        function generateUserId(data) {
            let max = 0;

            data.forEach(user => {
                if (!user.userId) return;

                let idString = user.userId.replace(/\D/g, "");
                let number = parseInt(idString);

                if (!isNaN(number) && number > max) {
                    max = number;
                }
            });

            let formatted = "USR" + String(max + 1).padStart(5, '0');
            $("#userId").val(formatted);
        }

        async function loadUsers() {

            const data = await Api.get("/api/user");
            if (!data) return;

            table = Table.init("#datatablesIndex", {
                data: data,
                columns: [
                    Table.rowNumber(),
                    { data: "userId", className: "text-nowrap" },
                    { data: "fullname" },
                    { data: "username" },
                    {
                        data: "roles",
                        render: d => Array.isArray(d) ? d.join(", ") : "-"
                    },
                    Table.action(renderAction, canUpdate || canDelete)
                ]
            });
        }


        function renderAction(data) {

            let buttons = `<div class="btn-group btn-group-sm">`;

            if (canUpdate) {
                buttons += `
                    <a href="/user/detail?id=${data.id}" class="btn btn-info">
                        <i class="fas fa-eye"></i>
                    </a>
                `;
            }

            if (canDelete) {
                buttons += `
                    <button class="btn btn-danger"
                            onclick="deleteUser('${data.id}')">
                        <i class="fas fa-trash"></i>
                    </button>
                `;
            }

            buttons += `</div>`;
            return buttons;
        }

        $("#createUserForm").submit(async function (e) {
            e.preventDefault();

            const payload = {
                username: e.target.username.value,
                fullname: e.target.fullname.value,
                password: e.target.password.value,
                roleIds: $("#roleSelect").val()
            };

            const res = await Api.post("/api/user", payload);

            if (res && res.ok) {

                await Alert.success("User created successfully");

                $("#createUser").modal("hide");
                e.target.reset();
                loadUsers();

            } else {

                Alert.error("Failed to create user");

            }
        });

        async function deleteUser(id) {

            const confirm = await Alert.deleteConfirm("User");
            if (!confirm.isConfirmed) return;

            const res = await Api.delete(`/api/user/${id}`);

            if (res && res.ok) {

                await Alert.success("User deleted successfully");
                loadUsers();

            } else {

                Alert.error("Failed to delete user");

            }
        }

        $('#createUser').on('shown.bs.modal', function () {
            const data = table.rows().data().toArray();
            generateUserId(data);
            loadRolesDropdown();
        });


        $(window).on('resize', function () {
            clearTimeout(window.datatableResizeTimeout);
            window.datatableResizeTimeout = setTimeout(function () {
                if (table) {
                    table.columns.adjust().responsive.recalc();
                }
            }, 250);
        });

        document.addEventListener('visibilitychange', function () {
            if (!document.hidden && table) {
                setTimeout(() => table.columns.adjust().responsive.recalc(), 100);
            }
        });

    </script>
</body>