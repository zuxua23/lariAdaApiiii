<body class="hold-transition sidebar-mini layout-fixed">

    <div class="wrapper">

        @Html.Partial("_Navbar")
        @Html.Partial("_Sidebar")
        @Html.Partial("_Views")

        <div class="content-wrapper">

            <section class="content-header">
                <div class="container-fluid">
                    <div class="d-flex align-items-center justify-content-between flex-wrap mb-4">

                        <div class="d-flex align-items-center">
                            <div class="header-icon mr-3">
                                <i class="fas fa-map nav-icon text-primary"
                                   style="font-size: 2.25rem; opacity: 0.8;"></i>
                            </div>
                            <div>
                                <h1 class="h3 mb-1 text-dark font-weight-bold">Location Management</h1>
                                <p class="mb-0 text-muted small">Manage your location data</p>
                            </div>
                        </div>

                        <nav aria-label="breadcrumb" class="modern-breadcrumb">
                            <ol class="breadcrumb bg-transparent p-0 mb-0">
                                <li class="breadcrumb-item">
                                    <a href="/home" class="text-muted">
                                        <i class="fas fa-home mr-1"></i>Dashboard
                                    </a>
                                </li>
                                <li class="breadcrumb-item active">
                                    <i class="fas fa-map mr-1"></i>Location
                                </li>
                            </ol>
                        </nav>

                    </div>
                </div>
            </section>

            <section class="content">
                <div class="container-fluid">

                    <div class="row">
                        <div class="col-12">

                            <div class="card card-primary card-outline shadow-lg">

                                <div class="card-header bg-white border-0 pb-0">
                                    <div class="d-flex justify-content-between align-items-center">
                                        <h3 class="card-title font-weight-bold mb-0">
                                            <i class="fas fa-list mr-2 text-primary"></i>
                                            Location List
                                        </h3>

                                        <button class="btn btn-primary btn-icon-split"
                                                data-toggle="modal"
                                                data-target="#createLocation">
                                            <span class="icon text-white-50">
                                                <i class="fas fa-plus"></i>
                                            </span>
                                            <span class="text">Create</span>
                                        </button>
                                    </div>
                                </div>

                                <div class="card-body pt-3">

                                    <div class="table-responsive">
                                        <table id="datatablesIndex" class="table table-hover">
                                            <thead class="thead-light">
                                                <tr>
                                                    <th class="text-center" width="60">#</th>
                                                    <th>Location ID</th>
                                                    <th>Name</th>
                                                    <th>Description</th>
                                                    <th class="text-center" width="160">Actions</th>
                                                </tr>
                                            </thead>
                                        </table>
                                    </div>

                                </div>
                            </div>

                        </div>
                    </div>

                </div>
            </section>

        </div>

        @Html.Partial("_Footer")

    </div>

    <div class="modal fade" id="createLocation">
        <div class="modal-dialog">
            <div class="modal-content">

                <div class="modal-header">
                    <h5>Create Location</h5>
                    <button class="close" data-dismiss="modal">&times;</button>
                </div>

                <form id="createLocationForm">
                    <div class="modal-body">

                        <div class="form-group">
                            <label>
                                <i class="fas fa-hashtag text-muted mr-2"></i>
                                Location ID
                            </label>
                            <input type="text" name="locId" class="form-control" required>
                        </div>

                        <div class="form-group">
                            <label>
                                <i class="fas fa-tag text-muted mr-2"></i>
                                Name <span class="text-danger">*</span>
                            </label>
                            <input type="text" name="name" class="form-control" required>
                        </div>

                        <div class="form-group">
                            <label>
                                <i class="fas fa-align-left text-muted mr-2"></i>
                                Description
                            </label>
                            <textarea name="description" class="form-control"></textarea>
                        </div>

                    </div>

                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-dismiss="modal">Close</button>
                        <button type="submit" class="btn btn-primary btn-modern">
                            <i class="fas fa-save mr-1"></i>Create
                        </button>
                    </div>
                </form>

            </div>
        </div>
    </div>

    @Html.Partial("_BaseScript")

    <script>

        let table;

        $(document).ready(function () {
            loadLocations();
        });

        async function loadLocations() {

            const response = await fetch("/api/location", {
                method: "GET",
                credentials: "include"
            });

            if (response.status === 401) {
                window.location.href = "/login";
                return;
            }

            if (response.status === 403) {
                Swal.fire("Akses ditolak", "", "warning");
                return;
            }

            const data = await response.json();

            if ($.fn.DataTable.isDataTable('#datatablesIndex')) {
                $('#datatablesIndex').DataTable().clear().destroy();
            }

                table = $("#datatablesIndex").DataTable({
                    data: data,

                    responsive: true,
                    pageLength: 25,
                    lengthMenu: [[10, 25, 50, 100, -1], [10, 25, 50, 100, "All"]], 

                    autoWidth: false, 
                    columnDefs: [
                        {
                            targets: 0,
                            data: null,
                            render: (data, type, row, meta) =>
                                meta.row + meta.settings._iDisplayStart + 1,
                            className: "text-center",
                            orderable: false,
                            width: "5%"
                        },
                        {
                            targets: 1,
                            data: "locId",
                            className: "text-nowrap",
                            width: "15%"
                        },
                        {
                            targets: 2,
                            data: "name",
                            width: "30%",
                            responsivePriority: 1 
                        },
                        {
                            targets: 3,
                            data: "description",
                            width: "35%"
                        },
                        {
                            targets: 4,
                            data: null,
                            render: data => `
                                <div class="btn-group btn-group-sm">
                                    <a href="/location/detail?id=${data.id}" class="btn btn-info">
                                        <i class="fas fa-eye"></i>
                                    </a>
                                    <button class="btn btn-danger"
                                            onclick="deleteLocation('${data.id}')">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </div>
                            `,
                            className: "text-center",
                            orderable: false,
                            width: "15%",
                            responsivePriority: 2 
                        }
                    ],

                    language: {
                        search: "_INPUT_",
                        searchPlaceholder: " Search location...",
                        lengthMenu: "Show _MENU_ Data",
                        paginate: { first: "«", last: "»", next: "›", previous: "‹" }
                    },

                    dom: "<'row mb-3'<'col-md-6'l><'col-md-6'f>>" +
                         "<'table-responsive card-body p-0't>" +
                         "<'row mt-3'<'col-md-5'i><'col-md-7'p>>",

                    drawCallback: function() {
                        $('.dataTables_length select').addClass('custom-select custom-select-sm rounded');
                        $('.dataTables_filter input').addClass('form-control rounded shadow-sm');

                        if($.fn.responsive){
                            table.responsive.recalc();
                        }
                    }
                });
            }

        $("#createLocationForm").submit(async function (e) {
            e.preventDefault();

            const form = e.target;

            const payload = {
                locId: form.locId.value,
                name: form.name.value,
                description: form.description.value
            };

            const response = await fetch("/api/location", {
                method: "POST",
                credentials: "include",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify(payload)
            });

            if (response.ok) {

                Swal.fire({
                    icon: "success",
                    title: "Berhasil",
                    text: "Location berhasil dibuat",
                    timer: 1500,
                    showConfirmButton: false
                }).then(() => {
                    $("#createLocation").modal("hide");
                    form.reset();
                    loadLocations();
                });

            } else {

                Swal.fire({
                    icon: "error",
                    title: "Gagal",
                    text: "Create location gagal"
                });

            }
        });

        async function deleteLocation(id) {

            const result = await Swal.fire({
                title: "Yakin?",
                text: "Location akan dihapus!",
                icon: "warning",
                showCancelButton: true,
                confirmButtonColor: "#d33",
                cancelButtonColor: "#6c757d",
                confirmButtonText: "Ya, hapus!",
                cancelButtonText: "Batal"
            });

            if (!result.isConfirmed) return;

            const response = await fetch(`/api/location/${id}`, {
                method: "DELETE",
                credentials: "include"
            });

            if (response.ok) {

                Swal.fire({
                    icon: "success",
                    title: "Berhasil",
                    text: "Location berhasil dihapus",
                    timer: 1500,
                    showConfirmButton: false
                }).then(() => loadLocations());

            } else {

                Swal.fire({
                    icon: "error",
                    title: "Gagal",
                    text: "Delete location gagal"
                });

            }
        }

    </script>

</body>