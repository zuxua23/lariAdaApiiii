<body class="hold-transition sidebar-mini layout-fixed">

    <div class="wrapper">

        @Html.Partial("_Navbar")
        @Html.Partial("_Sidebar")

        <div class="content-wrapper">

            <div class="content-header">

                <div class="container-fluid">

                    <div class="row mb-2">

                        <div class="col-sm-6">
                            <h1>Detail Picking List</h1>
                        </div>

                        <div class="col-sm-6">
                            <ol class="breadcrumb float-sm-right">
                                <li class="breadcrumb-item"><a href="/home">Dashboard</a></li>
                                <li class="breadcrumb-item"><a href="/pickinglist">Picking List</a></li>
                                <li class="breadcrumb-item active">Detail</li>
                            </ol>
                        </div>

                    </div>
                </div>
            </div>

            <section class="content">
                <div class="container-fluid">

                    <div class="card card-primary">

                        <div class="card-body">

                            <div class="form-group">
                                <label>DO Number</label>
                                <input id="doNumber" class="form-control">
                            </div>

                            <select id="scannerType" class="form-control" required>
                                <option value="">-- Pilih Scanner --</option>
                                <option value="RFID">RFID</option>
                                <option value="QR">QR</option>
                            </select>

                            <div id="details"></div>

                            <button class="btn btn-success mb-2" onclick="addDetail()">+ Item</button>

                            <div class="d-flex justify-content-end">
                                <button class="btn btn-primary" onclick="updateDO()">Update</button>
                            </div>

                        </div>

                    </div>

                </div>
            </section>

        </div>

        @Html.Partial("_Footer")

    </div>

    @Html.Partial("_BaseScript")

    <script>

        let id = "@ViewData["id"]";

        $(document).ready(load);

        async function load() {

            const res = await fetch(`/api/pickinglist/${id}`, {
                method: "GET",
                credentials: "include"
            });

            const data = await res.json();

            $("#doNumber").val(data.doNumber);
            $("#scannerType").val(data.scannerType);

            data.details.forEach(d => {
                addDetail(d.itemId, d.qtyRequired);
            });
        }

           async function loadItemDropdown(selectedId = "") {

            const res = await fetch("/api/item", {
                method: "GET",
                credentials: "include"
            });

            const data = await res.json();

            let options = `<option value="">-- Select Item --</option>`;

            data.forEach(item => {
                options += `<option value="${item.id}">${item.itemName}</option>`;
            });

            let lastSelect = $(".item-select").last();
            lastSelect.html(options);

            if (selectedId) {
                lastSelect.val(selectedId);
            }
        }
        function addDetail(selectedId = "", qty = "") {

            $("#details").append(`
                <div class="row mb-2 detail-item align-items-center">
                    <div class="col">
                        <select class="form-control item-select">
                            <option value="">-- Select Item --</option>
                        </select>
                    </div>
                    <div class="col">
                        <input class="form-control qty" value="${qty}" type="number">
                    </div>
                    <div class="col-2 text-center">
                        <button type="button" class="btn btn-danger btn-sm remove-item">Hapus</button>
                    </div>
                </div>
            `);

            loadItemDropdown(selectedId);
        }

        async function updateDO() {

            let details = [];

            $("#details .row").each(function () {
                details.push({
                    itemId: $(this).find(".itemId").val(),
                    qtyRequired: parseInt($(this).find(".qty").val())
                });
            });

            const payload = {
                doNumber: $("#doNumber").val(),
                scannerType: $("#scannerType").val(),
                details
            };

            const res = await fetch(`/api/do/${id}`, {
                method: "PUT",
                credentials: "include",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify(payload)
            });

            if (res.ok) {
                Swal.fire({
                    icon: "success",
                    title: "Updated",
                    timer: 1500,
                    showConfirmButton: false
                }).then(() => {
                    window.location.href = "/do";
                });
            } else {
                Swal.fire({
                    icon: "error",
                    title: "Error",
                    text: "Failed to update"
                });
            }
        }

    </script>

</body>