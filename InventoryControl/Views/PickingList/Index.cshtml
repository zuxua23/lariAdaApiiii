<body class="hold-transition sidebar-mini layout-fixed">

    <div class="wrapper">

        @Html.Partial("_Navbar")
        @Html.Partial("_Sidebar")
        @Html.Partial("_Views")

        <div class="content-wrapper">

            <section class="content-header">
                <div class="container-fluid">
                    <div class="d-flex align-items-center justify-content-between flex-wrap mb-4">

                        <div class="d-flex align-items-center">
                            <div class="header-icon mr-3">
                                <i class="fas fa-clipboard-list nav-icon text-primary"
                                   style="font-size: 2.25rem; opacity: 0.8;"></i>
                            </div>
                            <div>
                                <h1 class="h3 mb-1 text-dark font-weight-bold">Picking List</h1>
                                <p class="mb-0 text-muted small">Manage delivery picking process</p>
                            </div>
                        </div>

                        <nav aria-label="breadcrumb" class="modern-breadcrumb">
                            <ol class="breadcrumb bg-transparent p-0 mb-0">
                                <li class="breadcrumb-item">
                                    <a href="/home" class="text-muted">
                                        <i class="fas fa-home mr-1"></i>Dashboard
                                    </a>
                                </li>
                                <li class="breadcrumb-item active">
                                    <i class="fas fa-clipboard-list mr-1"></i>Picking List
                                </li>
                            </ol>
                        </nav>

                    </div>
                </div>
            </section>

            <section class="content">
                <div class="container-fluid">

                    <div class="row">
                        <div class="col-12">

                            <div class="card card-primary card-outline shadow-lg">

                                <div class="card-header bg-white border-0 pb-0">
                                    <div class="d-flex justify-content-between align-items-center">
                                        <h3 class="card-title font-weight-bold mb-0">
                                            <i class="fas fa-list mr-2 text-primary"></i>
                                            Picking List Data
                                        </h3>

                                        <button class="btn btn-primary btn-icon-split"
                                                data-toggle="modal"
                                                data-target="#createPickingList">
                                            <span class="icon text-white-50">
                                                <i class="fas fa-plus"></i>
                                            </span>
                                            <span class="text">Create</span>
                                        </button>
                                    </div>
                                </div>

                                <div class="card-body pt-3">

                                    <div class="table-responsive">  
                                        <table id="datatablesIndex" class="table table-hover">
                                            <thead class="thead-light">
                                                <tr>
                                                    <th class="text-center" width="60">#</th>
                                                    <th class="text-nowrap">DO Number</th>
                                                    <th>Status</th>
                                                    <th>Create Date</th>
                                                    <th class="text-center" width="160">Actions</th>
                                                </tr>
                                            </thead>
                                        </table>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </section>
        </div>
        @Html.Partial("_Footer")
    </div>

    <div class="modal fade" id="createPickingList">
        <div class="modal-dialog">
            <div class="modal-content">

                <div class="modal-header">
                    <h5>Create Picking List</h5>
                    <button class="close" data-dismiss="modal">&times;</button>
                </div>

                <form id="createPickingListForm">
                    <div class="modal-body">

                        <div class="form-group">
                            <label>
                                <i class="fas fa-barcode text-muted mr-2"></i>
                                DO Number <span class="text-danger">*</span>
                            </label>
                            <input type="text" name="doNumber" class="form-control" required>
                        </div>

                        <div id="detailContainer"></div>

                        <button type="button" class="btn btn-success btn-sm mt-2" onclick="addDetail()">
                            <i class="fas fa-plus mr-1"></i>Item
                        </button>

                    </div>

                    <div class="modal-footer">
                        <button type="submit" class="btn btn-primary btn-modern">
                            <i class="fas fa-save mr-1"></i>Create
                        </button>
                    </div>
                </form>

            </div>
        </div>
    </div>

    @Html.Partial("_BaseScript")

    <script>

        async function loadItemDropdown() {

            const response = await fetch("/api/item", {
                method: "GET",
                credentials: "include"
            });

            const data = await response.json();

            let options = `<option value="">-- Select ITEM --</option>`;

            data.forEach(item => {
                options += `<option value="${item.id}">${item.itemName}</option>`;
            });

            $(".item-select").each(function () {
                if ($(this).children().length <= 1) {
                    $(this).html(options);
                }
            });
        }

        let table;

        $(document).ready(function () {
            loadDO();
        });

        async function loadDO() {

            const response = await fetch("/api/pickinglist", {
                method: "GET",
                credentials: "include"
            });

            if (response.status === 401) {
                window.location.href = "/login";
                return;
            }

            if (response.status === 403) {
                Swal.fire("Akses ditolak", "", "warning");
                return;
            }

            const data = await response.json();

            if ($.fn.DataTable.isDataTable('#datatablesIndex')) {
                $('#datatablesIndex').DataTable().clear().destroy();
            }

                table = $("#datatablesIndex").DataTable({
                    data: data,
                    responsive: true,
                    pageLength: 10, 
                    lengthMenu: [[10, 25, 50, 100, -1], [10, 25, 50, 100, "All"]], 

                    autoWidth: false, 
                    columnDefs: [
                        {
                            targets: 0,
                            data: null,
                            render: (d, t, r, m) => m.row + m.settings._iDisplayStart + 1,
                            className: "text-center",
                            orderable: false,
                            width: "5%" 
                        },
                        {
                            targets: 1,
                            data: "doNumber",
                            className: "text-nowrap", 
                            width: "25%", 
                            responsivePriority: 1 
                        },
                        {
                            targets: 2,
                            data: "status",
                            width: "15%" 
                        },
                        {
                            targets: 3,
                            data: "createdAt",
                            width: "35%", 
                            render: function(data) {
                                if (!data) return '-';
                                const date = new Date(data);
                                return date.toLocaleString('id-ID', {
                                    day: '2-digit',
                                    month: 'short',
                                    year: 'numeric',
                                    hour: '2-digit',
                                    minute: '2-digit'
                                });
                            }
                        },
                        {
                            targets: 4,
                            data: null,
                            render: data => `
                                <div class="btn-group btn-group-sm">
                                    <a href="/pickinglist/detail?id=${data.doId}" class="btn btn-info">
                                        <i class="fas fa-eye"></i>
                                    </a>
                                    <button class="btn btn-danger"
                                            onclick="deletePickingList('${data.doId}')">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </div>
                            `,
                            className: "text-center",
                            orderable: false,
                            width: "20%", 
                            responsivePriority: 2 
                        }
                    ],
                    language: {
                        search: "_INPUT_",
                        searchPlaceholder: " Search picking list...",
                        lengthMenu: "Show _MENU_ Data",
                        paginate: { first: "«", last: "»", next: "›", previous: "‹" }
                    },
                    dom: "<'row mb-3'<'col-md-6'l><'col-md-6'f>>" +
                         "<'table-responsive card-body p-0't>" +
                         "<'row mt-3'<'col-md-5'i><'col-md-7'p>>",

                    drawCallback: function() {
                        $('.dataTables_length select').addClass('custom-select custom-select-sm rounded');
                        $('.dataTables_filter input').addClass('form-control rounded shadow-sm');

                        if($.fn.responsive){
                            table.responsive.recalc();
                        }
                    }
                });
        }

        $(document).on("click", ".remove-item", function () {

            let row = $(this).closest(".detail-item");

            Swal.fire({
                title: "Hapus item?",
                icon: "warning",
                showCancelButton: true,
                confirmButtonText: "Ya, hapus"
            }).then((result) => {
                if (result.isConfirmed) {
                    row.remove();

                    if ($("#detailContainer .detail-item").length === 0) {
                        $("#detailContainer").html("");
                    }
                }
            });
        });

        function addDetail() {

            if ($("#detailContainer .item-header").length === 0) {
                $("#detailContainer").append(`
                    <div class="row mb-2 item-header font-weight-bold">
                        <div class="col">Item</div>
                        <div class="col">Qty</div>
                        <div class="col-2 text-center">Action</div>
                    </div>
                `);
            }

            $("#detailContainer").append(`
                <div class="row mb-2 detail-item align-items-center">
                    <div class="col">
                        <select class="form-control item-select" required></select>
                    </div>
                    <div class="col">
                        <input class="form-control qty" placeholder="Qty" type="number">
                    </div>
                    <div class="col-2 text-center">
                        <button type="button" class="btn btn-danger btn-sm remove-item">
                            <i class="fas fa-trash"></i>
                        </button>
                    </div>
                </div>
            `);

            loadItemDropdown();
        }

        $("#createPickingListForm").submit(async function (e) {
            e.preventDefault();

            const form = e.target;

            let details = [];

            $("#detailContainer .detail-item").each(function () {
                details.push({
                    itemId: $(this).find(".item-select").val(),
                    qtyRequired: parseInt($(this).find(".qty").val())
                });
            });

            const payload = {
                doNumber: form.doNumber.value,
                details
            };

            const response = await fetch("/api/pickinglist", {
                method: "POST",
                credentials: "include",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify(payload)
            });

            if (response.ok) {

                Swal.fire({
                    icon: "success",
                    title: "Berhasil",
                    text: "Picking List berhasil dibuat",
                    timer: 1500,
                    showConfirmButton: false
                }).then(() => {
                    $("#createPickingList").modal("hide");
                    form.reset();
                    loadDO();
                });

            } else {

                Swal.fire({
                    icon: "error",
                    title: "Gagal",
                    text: "Create picking list gagal"
                });

            }
        });

        async function deletePickingList(id) {

            const result = await Swal.fire({
                title: "Yakin?",
                text: "Data akan dihapus!",
                icon: "warning",
                showCancelButton: true,
                confirmButtonColor: "#d33",
                cancelButtonColor: "#6c757d",
                confirmButtonText: "Ya, hapus!",
                cancelButtonText: "Batal"
            });

            if (!result.isConfirmed) return;

            const response = await fetch(`/api/pickinglist/${id}`, {
                method: "DELETE",
                credentials: "include"
            });

            if (response.ok) {

                Swal.fire({
                    icon: "success",
                    title: "Berhasil",
                    text: "Data berhasil dihapus",
                    timer: 1500,
                    showConfirmButton: false
                }).then(() => loadDO());

            } else {

                Swal.fire({
                    icon: "error",
                    title: "Gagal",
                    text: "Delete gagal"
                });

            }
        }
            $(window).on('resize', function() {
                clearTimeout(window.datatableResizeTimeout);
                window.datatableResizeTimeout = setTimeout(function() {
                    if (table) {
                        table.columns.adjust().responsive.recalc();
                    }
                }, 250);
            });

            $(document).ready(function() {
                $(window).trigger('resize');
            });

            document.addEventListener('visibilitychange', function() {
                if (!document.hidden && table) {
                    setTimeout(() => table.columns.adjust().responsive.recalc(), 100);
                }
            });
    </script>

</body>